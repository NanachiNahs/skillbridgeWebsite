---
const pathname = Astro.url.pathname;
---

<aside class="fixed top-0 left-0 h-screen w-64 glass-card border-r border-white/10 flex flex-col z-50">
    <div class="p-6 flex items-center gap-3 border-b border-white/5">
        <div class="w-10 h-10 bg-[#00D632] rounded-xl flex items-center justify-center text-black font-black text-xl shadow-[0_0_15px_rgba(0,214,50,0.4)]">S</div>
        <span class="font-bold tracking-tighter text-xl">SkillBridge</span>
    </div>
    <nav class="flex-1 p-4 space-y-2">
        <a href="/home" class={`flex items-center gap-3 px-4 py-3 rounded-xl font-bold text-sm transition ${pathname.includes('home') || pathname === '/' ? 'bg-[#00D632]/10 text-[#00D632] border border-[#00D632]/20' : 'text-zinc-400 hover:bg-white/5'}`}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
            Dashboard
        </a>
        <a href="/users" class={`flex items-center gap-3 px-4 py-3 rounded-xl font-bold text-sm transition ${pathname.includes('users') ? 'bg-[#00D632]/10 text-[#00D632] border border-[#00D632]/20' : 'text-zinc-400 hover:bg-white/5'}`}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
            Users
        </a>
        <a href="/ai-insights" class={`flex items-center gap-3 px-4 py-3 rounded-xl font-bold text-sm transition relative ${pathname.includes('ai-insights') ? 'bg-[#00D632]/10 text-[#00D632] border border-[#00D632]/20' : 'text-zinc-400 hover:bg-white/5'}`}>
            <svg class={`w-5 h-5 ${pathname.includes('ai-insights') ? 'text-[#00D632]' : 'text-purple-400'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            AI Insights
            <span class="absolute right-4 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-purple-500 animate-pulse"></span>
        </a>
    </nav>
    <div class="p-6 border-t border-white/5">
        <button id="logoutBtn" class="w-full flex items-center justify-center gap-2 px-4 py-2 bg-zinc-800 text-white rounded-lg hover:bg-red-500 hover:text-white transition text-sm font-bold">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
            Logout
        </button>
    </div>
</aside>

<script>
    // Logout handler — clears both localStorage and the session cookie
    document.getElementById('logoutBtn')?.addEventListener('click', () => {
        localStorage.removeItem('sb_admin');
        // Expire the session cookie immediately
        document.cookie = 'sb_admin_session=; path=/; max-age=0; SameSite=Strict';
        window.location.href = '/login';
    });
</script>
