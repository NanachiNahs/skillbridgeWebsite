---
import '../styles/global.css';
const pageTitle = "SkillBridge - Schedule Smarter";
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
  </head>
  <body class="bg-black text-white font-['Inter'] selection:bg-[#00D632] selection:text-black overflow-x-hidden">
    
    <nav class="fixed top-6 left-0 w-full z-50 px-6 pointer-events-none">
      <div class="max-w-7xl mx-auto flex justify-between items-center">
        <div class="pointer-events-auto flex items-center gap-2">
          <div class="w-10 h-10 bg-[#00D632] rounded-xl flex items-center justify-center text-black font-black text-xl shadow-[0_0_20px_rgba(0,214,50,0.5)]">S</div>
          <span class="hidden md:block font-bold tracking-tighter text-xl">SkillBridge</span>
        </div>

        <div class="pointer-events-auto hidden md:flex items-center gap-8 bg-zinc-900/90 backdrop-blur-md px-8 py-4 rounded-full border border-white/10 shadow-2xl">
          <a href="#problem" class="text-xs font-bold uppercase tracking-widest hover:text-[#00D632] transition">Problem</a>
          <a href="#features" class="text-xs font-bold uppercase tracking-widest hover:text-[#00D632] transition">Features</a>
          <a href="#how-it-works" class="text-xs font-bold uppercase tracking-widest hover:text-[#00D632] transition">Process</a>
          <a href="#team" class="text-xs font-bold uppercase tracking-widest hover:text-[#00D632] transition">Team</a>
        </div>

        <a href="#contact" class="pointer-events-auto px-6 py-3 bg-[#00D632] text-black font-black uppercase tracking-wider text-sm rounded-full hover:bg-white hover:scale-105 transition duration-300 shadow-[0_0_20px_rgba(0,214,50,0.4)]">
          Get Started
        </a>
      </div>
    </nav>

    <header class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-[#00D632] rounded-full blur-[150px] opacity-15"></div>
      
      <div class="absolute top-32 left-10 md:left-32 animate-bounce duration-[3000ms] opacity-30">
         <span class="block text-6xl rotate-12">🔧</span>
      </div>
      <div class="absolute bottom-32 right-10 md:right-32 animate-bounce duration-[4000ms] opacity-30">
         <span class="block text-6xl -rotate-12">⚡</span>
      </div>

      <div class="relative z-10 text-center max-w-5xl px-6">
        <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-zinc-900 border border-zinc-800 mb-8">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#00D632] opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-[#00D632]"></span>
            </span>
            <span class="text-xs font-bold uppercase tracking-widest text-zinc-400">Live in Kuching & Sarawak</span>
        </div>

        <h1 class="text-5xl md:text-9xl font-black uppercase tracking-tighter leading-[0.9] mb-8">
          Stop Relying On<br />
          <span class="text-[#00D632]">Word of Mouth</span>
        </h1>
        <p class="text-xl md:text-2xl text-zinc-400 max-w-2xl mx-auto font-medium mb-12">
          The all-in-one platform for finding trusted contractors, ordering hardware, and managing home repairs. Verified professionals, transparent pricing.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-6 justify-center">
            <a href="#contact" class="px-8 py-4 bg-white text-black text-lg font-black uppercase tracking-widest rounded-2xl hover:bg-[#00D632] hover:scale-105 transition shadow-xl">
                Find a Pro
            </a>
            <a href="#contact" class="px-8 py-4 bg-zinc-900 text-white border border-zinc-700 text-lg font-black uppercase tracking-widest rounded-2xl hover:bg-zinc-800 transition">
                Join as Pro
            </a>
        </div>
      </div>
    </header>

    <section class="border-y border-white/10 bg-zinc-900 overflow-hidden py-10">
        <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-12 text-center">
            <div>
                <div class="text-5xl md:text-6xl font-black text-[#00D632] tracking-tighter">172K+</div>
                <div class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-500 mt-2">Households</div>
            </div>
            <div>
                <div class="text-5xl md:text-6xl font-black text-white tracking-tighter">MYR 415M</div>
                <div class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-500 mt-2">Market Size</div>
            </div>
            <div>
                <div class="text-5xl md:text-6xl font-black text-[#00D632] tracking-tighter">100%</div>
                <div class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-500 mt-2">Verified Focus</div>
            </div>
        </div>
    </section>

    <section id="problem" class="py-24 px-6 bg-black">
        <div class="max-w-5xl mx-auto text-center">
            <h2 class="text-3xl md:text-5xl font-black uppercase tracking-tighter mb-16">Why is it so hard to find help?</h2>
            <div class="grid md:grid-cols-2 gap-8">
                <div class="bg-zinc-900 p-10 rounded-3xl border border-zinc-800 hover:border-red-500/50 transition duration-500">
                    <div class="text-6xl mb-6">?</div>
                    <h3 class="text-2xl font-bold uppercase text-red-500 mb-4">Unreliable Sources</h3>
                    <p class="text-zinc-400 text-lg">Most people rely on word-of-mouth, leading to limited options and unverified quality.</p>
                </div>
                <div class="bg-zinc-900 p-10 rounded-3xl border border-zinc-800 hover:border-orange-500/50 transition duration-500">
                    <div class="text-6xl mb-6">!</div>
                    <h3 class="text-2xl font-bold uppercase text-orange-500 mb-4">Quality Roulette</h3>
                    <p class="text-zinc-400 text-lg">Without a verified system, you never know if the contractor showing up is actually qualified.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="features" class="py-24 px-6 bg-zinc-900">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-6xl font-black uppercase tracking-tighter mb-4">The Solution</h2>
                <p class="text-zinc-400 text-xl">We solve these problems with a full ecosystem approach.</p>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                <div class="group bg-black p-8 rounded-[2rem] border border-white/10 hover:border-[#00D632] transition duration-300">
                    <div class="w-16 h-16 bg-zinc-900 rounded-2xl flex items-center justify-center text-4xl mb-6 text-[#00D632]">🔀</div>
                    <h3 class="text-2xl font-black uppercase mb-4">Shuffle</h3>
                    <p class="text-zinc-400">Don't know who to hire? Our intelligent Shuffle feature automatically matches you with rated contractors.</p>
                </div>
                <div class="group bg-black p-8 rounded-[2rem] border border-white/10 hover:border-[#00D632] transition duration-300">
                    <div class="w-16 h-16 bg-zinc-900 rounded-2xl flex items-center justify-center text-4xl mb-6 text-[#00D632]">📦</div>
                    <h3 class="text-2xl font-black uppercase mb-4">Hardware</h3>
                    <p class="text-zinc-400">Order parts directly through the app. We partner with local hardware stores for instant delivery.</p>
                </div>
                <div class="group bg-black p-8 rounded-[2rem] border border-white/10 hover:border-[#00D632] transition duration-300">
                    <div class="w-16 h-16 bg-zinc-900 rounded-2xl flex items-center justify-center text-4xl mb-6 text-[#00D632]">🛡️</div>
                    <h3 class="text-2xl font-black uppercase mb-4">Verified</h3>
                    <p class="text-zinc-400">All professionals are background-checked. Payments are held securely in the app until the job is done.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-20 px-6 bg-black">
        <div class="max-w-5xl mx-auto text-center">
            <h3 class="text-2xl md:text-3xl font-black uppercase tracking-widest text-zinc-500 mb-12">Everything You Need</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                <div class="bg-zinc-900 p-8 rounded-2xl border border-zinc-800 hover:-translate-y-2 hover:bg-[#00D632] hover:text-black transition duration-300 cursor-pointer group">
                    <div class="text-5xl mb-4 group-hover:scale-110 transition">🔧</div>
                    <div class="font-bold text-lg uppercase tracking-wider">Plumbers</div>
                </div>
                <div class="bg-zinc-900 p-8 rounded-2xl border border-zinc-800 hover:-translate-y-2 hover:bg-[#00D632] hover:text-black transition duration-300 cursor-pointer group">
                    <div class="text-5xl mb-4 group-hover:scale-110 transition">⚡</div>
                    <div class="font-bold text-lg uppercase tracking-wider">Electrical</div>
                </div>
                <div class="bg-zinc-900 p-8 rounded-2xl border border-zinc-800 hover:-translate-y-2 hover:bg-[#00D632] hover:text-black transition duration-300 cursor-pointer group">
                    <div class="text-5xl mb-4 group-hover:scale-110 transition">🧹</div>
                    <div class="font-bold text-lg uppercase tracking-wider">Cleaners</div>
                </div>
                <div class="bg-zinc-900 p-8 rounded-2xl border border-zinc-800 hover:-translate-y-2 hover:bg-[#00D632] hover:text-black transition duration-300 cursor-pointer group">
                    <div class="text-5xl mb-4 group-hover:scale-110 transition">🔨</div>
                    <div class="font-bold text-lg uppercase tracking-wider">Handyman</div>
                </div>
            </div>
        </div>
    </section>

    <section id="how-it-works" class="py-24 bg-[#00D632] text-black px-6">
        <div class="max-w-7xl mx-auto">
             <h2 class="text-4xl md:text-8xl font-black uppercase tracking-tighter mb-16 text-center">How It Works</h2>
             <div class="grid md:grid-cols-5 gap-4">
                <div class="bg-black/10 p-6 rounded-3xl border border-black/10 text-center">
                    <div class="text-5xl font-black mb-2">1</div>
                    <div class="font-bold uppercase tracking-wide mb-1">Sign Up</div>
                    <p class="text-xs font-bold opacity-60">Create Account</p>
                </div>
                <div class="bg-black/10 p-6 rounded-3xl border border-black/10 text-center">
                    <div class="text-5xl font-black mb-2">2</div>
                    <div class="font-bold uppercase tracking-wide mb-1">Find</div>
                    <p class="text-xs font-bold opacity-60">Search or Shuffle</p>
                </div>
                <div class="bg-black/10 p-6 rounded-3xl border border-black/10 text-center">
                    <div class="text-5xl font-black mb-2">3</div>
                    <div class="font-bold uppercase tracking-wide mb-1">Book</div>
                    <p class="text-xs font-bold opacity-60">Select Time</p>
                </div>
                <div class="bg-black/10 p-6 rounded-3xl border border-black/10 text-center">
                    <div class="text-5xl font-black mb-2">4</div>
                    <div class="font-bold uppercase tracking-wide mb-1">Chat</div>
                    <p class="text-xs font-bold opacity-60">Talk In-App</p>
                </div>
                <div class="bg-black text-[#00D632] p-6 rounded-3xl shadow-2xl scale-105 text-center">
                    <div class="text-5xl font-black mb-2">5</div>
                    <div class="font-bold uppercase tracking-wide mb-1">Pay</div>
                    <p class="text-xs font-bold opacity-80">Secure Release</p>
                </div>
             </div>
        </div>
    </section>

    <section id="team" class="py-32 px-6">
        <div class="max-w-7xl mx-auto text-center">
            <h2 class="text-3xl font-bold uppercase tracking-[0.3em] text-zinc-500 mb-20">The Builders</h2>
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="bg-zinc-900 rounded-2xl p-8 hover:-translate-y-2 transition duration-300 border border-white/5">
                    <h3 class="text-2xl font-black text-white">Ronan</h3>
                    <div class="text-[#00D632] font-bold text-xs uppercase tracking-widest mb-4">CEO</div>
                    <p class="text-zinc-500 text-xs uppercase tracking-wide">Tech & Innovation</p>
                </div>
                <div class="bg-zinc-900 rounded-2xl p-8 hover:-translate-y-2 transition duration-300 border border-white/5">
                    <h3 class="text-2xl font-black text-white">Esmat</h3>
                    <div class="text-[#00D632] font-bold text-xs uppercase tracking-widest mb-4">CMO</div>
                    <p class="text-zinc-500 text-xs uppercase tracking-wide">Growth & Strategy</p>
                </div>
                <div class="bg-zinc-900 rounded-2xl p-8 hover:-translate-y-2 transition duration-300 border border-white/5">
                    <h3 class="text-2xl font-black text-white">Alister</h3>
                    <div class="text-[#00D632] font-bold text-xs uppercase tracking-widest mb-4">CAO</div>
                    <p class="text-zinc-500 text-xs uppercase tracking-wide">Ops & Admin</p>
                </div>
                <div class="bg-zinc-900 rounded-2xl p-8 hover:-translate-y-2 transition duration-300 border border-white/5">
                    <h3 class="text-2xl font-black text-white">Nurlaila</h3>
                    <div class="text-[#00D632] font-bold text-xs uppercase tracking-widest mb-4">CRO</div>
                    <p class="text-zinc-500 text-xs uppercase tracking-wide">Research</p>
                </div>
            </div>
        </div>
    </section>

    <footer id="contact" class="py-20 border-t border-white/10 bg-black">
        <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-10">
            <div class="text-left">
                <div class="text-4xl font-black tracking-tighter mb-4">SkillBridge</div>
                <p class="text-zinc-500 max-w-sm mb-6">Connecting Kuching's talent to opportunity. The smartest way to manage home repairs and finding work.</p>
            </div>
            
            <div class="bg-zinc-900 px-10 py-8 rounded-3xl text-center md:text-right border border-zinc-800">
                <p class="text-zinc-400 text-xs uppercase tracking-widest mb-2">Direct Line</p>
                <p class="text-2xl font-bold text-white mb-6">+6010-9221866</p>
                <a href="mailto:ronankuek@gmail.com" class="text-[#00D632] font-bold hover:underline">ronankuek@gmail.com</a>
                <p class="text-zinc-500 mt-2">Kuching, Sarawak</p>
            </div>
        </div>
        <div class="text-center mt-20 text-zinc-700 text-xs uppercase tracking-widest">
            © 2026 SkillBridge. Presented by Primate House.
        </div>
    </footer>

  </body>
</html>