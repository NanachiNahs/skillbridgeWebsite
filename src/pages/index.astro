---
import '../styles/global.css';

// --- IMAGE IMPORTS ---
import homepageImg from '../assets/homepage.jpeg';
import searchpageImg from '../assets/searchpage.jpeg';
import cartpageImg from '../assets/cartpage.jpeg';
import buildersImg from '../assets/builders.jpeg';

const pageTitle = "SkillBridge - Schedule Smarter";
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    
    <style>
      .animate-marquee {
        animation: marquee 30s linear infinite;
      }
      @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
      /* Grid Background Pattern */
      .bg-grid {
        background-size: 50px 50px;
        background-image: linear-gradient(to right, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
                          linear-gradient(to bottom, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
      }
      /* Accordion Animation */
      details > summary { list-style: none; }
      details > summary::-webkit-details-marker { display: none; }
      details[open] summary ~ * { animation: sweep .3s ease-in-out; }
      @keyframes sweep { 0% {opacity: 0; transform: translateY(-10px)} 100% {opacity: 1; transform: translateY(0)} }
    </style>
  </head>
  
  <body class="bg-black text-white font-['Inter'] selection:bg-[#00D632] selection:text-black overflow-x-hidden">
    
    <nav class="fixed top-6 left-0 w-full z-50 px-6 pointer-events-none">
      <div class="max-w-7xl mx-auto flex justify-between items-center">
        <div class="pointer-events-auto flex items-center gap-2">
          <div class="w-10 h-10 bg-[#00D632] rounded-xl flex items-center justify-center text-black font-black text-xl shadow-[0_0_20px_rgba(0,214,50,0.5)]">S</div>
          <span class="hidden md:block font-bold tracking-tighter text-xl">SkillBridge</span>
        </div>

        <div class="pointer-events-auto hidden md:flex items-center gap-8 bg-zinc-900/90 backdrop-blur-md px-8 py-4 rounded-full border border-white/10 shadow-2xl">
          <a href="#app-showcase" class="text-xs font-bold uppercase tracking-widest hover:text-[#00D632] transition">App</a>
          <a href="#earn" class="text-xs font-bold uppercase tracking-widest text-[#00D632] hover:text-white transition">For Pros</a>
          <a href="#features" class="text-xs font-bold uppercase tracking-widest hover:text-[#00D632] transition">Features</a>
          <a href="#team" class="text-xs font-bold uppercase tracking-widest hover:text-[#00D632] transition">Team</a>
        </div>

        <a href="#contact" class="pointer-events-auto px-6 py-3 bg-[#00D632] text-black font-black uppercase tracking-wider text-sm rounded-full hover:bg-white hover:scale-105 transition duration-300 shadow-[0_0_20px_rgba(0,214,50,0.4)]">
          Get Started
        </a>
      </div>
    </nav>

    <header class="relative pt-32 pb-10 overflow-hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-[#00D632] rounded-full blur-[180px] opacity-20 pointer-events-none"></div>

      <div class="relative z-10 text-center max-w-5xl mx-auto px-6">
        <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-zinc-900 border border-zinc-800 mb-8">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#00D632] opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-[#00D632]"></span>
            </span>
            <span class="text-xs font-bold uppercase tracking-widest text-zinc-400">Live in Kuching & Sarawak</span>
        </div>

        <h1 class="text-5xl md:text-9xl font-black uppercase tracking-tighter leading-[0.9] mb-8">
          Schedule<br />
          <span class="text-[#00D632]">Smarter</span>
        </h1>
        
        <p class="text-xl md:text-2xl text-zinc-400 max-w-2xl mx-auto font-medium mb-12 leading-relaxed">
          The verified marketplace connecting <span class="text-white">Homeowners</span> to trusted help, and <span class="text-white">Contractors</span> to steady income.
        </p>
      </div>
    </header>

    <div class="bg-[#00D632] py-3 overflow-hidden transform -skew-y-1 border-y-4 border-black mb-20">
      <div class="whitespace-nowrap animate-marquee inline-block text-black font-black text-xl md:text-2xl uppercase tracking-widest">
        &nbsp;• FIND HELP FAST • GET HIRED INSTANTLY • SECURE PAYMENTS • GROW YOUR BUSINESS • VERIFIED PROS • FIND HELP FAST • GET HIRED INSTANTLY • SECURE PAYMENTS • GROW YOUR BUSINESS • VERIFIED PROS •
      </div>
    </div>

    <section id="app-showcase" class="relative pb-32 overflow-hidden px-6">
       <div class="max-w-7xl mx-auto">
          <div class="flex flex-col md:flex-row items-center justify-center gap-8 md:-space-x-12 perspective-1000">
             <div class="relative z-10 w-64 md:w-80 transform md:-rotate-12 md:translate-y-12 transition hover:z-50 hover:scale-105 hover:rotate-0 duration-500">
                <div class="rounded-[2.5rem] border-8 border-zinc-800 overflow-hidden shadow-2xl bg-black">
                   <img src={searchpageImg.src} alt="Search Page" class="w-full h-auto object-cover" />
                </div>
             </div>
             <div class="relative z-30 w-72 md:w-96 transform transition hover:scale-105 duration-500 shadow-[0_0_100px_rgba(0,214,50,0.2)]">
                <div class="rounded-[3rem] border-8 border-zinc-800 overflow-hidden shadow-2xl bg-black">
                   <img src={homepageImg.src} alt="Home Page" class="w-full h-auto object-cover" />
                </div>
             </div>
             <div class="relative z-10 w-64 md:w-80 transform md:rotate-12 md:translate-y-12 transition hover:z-50 hover:scale-105 hover:rotate-0 duration-500">
                <div class="rounded-[2.5rem] border-8 border-zinc-800 overflow-hidden shadow-2xl bg-black">
                   <img src={cartpageImg.src} alt="Cart Page" class="w-full h-auto object-cover" />
                </div>
             </div>
          </div>
       </div>
    </section>

    <section class="border-y border-white/10 bg-zinc-900 overflow-hidden py-10">
        <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-12 text-center">
            <div>
                <div class="text-5xl md:text-6xl font-black text-[#00D632] tracking-tighter">172K+</div>
                <div class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-500 mt-2">Households</div>
            </div>
            <div>
                <div class="text-5xl md:text-6xl font-black text-white tracking-tighter">MYR 415M</div>
                <div class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-500 mt-2">Market Size</div>
            </div>
            <div>
                <div class="text-5xl md:text-6xl font-black text-[#00D632] tracking-tighter">100%</div>
                <div class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-500 mt-2">Verified Focus</div>
            </div>
        </div>
    </section>

    <section id="problem" class="py-24 px-6 bg-black">
        <div class="max-w-6xl mx-auto">
            <h2 class="text-3xl md:text-5xl font-black uppercase tracking-tighter mb-16 text-center">The <span class="text-[#00D632]">Disconnect</span></h2>
            <div class="grid md:grid-cols-2 gap-8">
                <div class="bg-zinc-900 p-10 rounded-3xl border border-zinc-800 hover:border-red-500/50 transition duration-500 group">
                    <p class="text-xs font-bold text-zinc-500 uppercase tracking-widest mb-4">For Homeowners</p>
                    <div class="text-5xl mb-6">?</div>
                    <h3 class="text-2xl font-bold uppercase text-white mb-4">Hard to find help</h3>
                    <p class="text-zinc-400 text-lg">Relying on word-of-mouth is slow. You never know if the stranger entering your home is actually qualified.</p>
                </div>
                <div class="bg-zinc-900 p-10 rounded-3xl border border-zinc-800 hover:border-[#00D632]/50 transition duration-500 group">
                    <p class="text-xs font-bold text-zinc-500 uppercase tracking-widest mb-4">For Contractors</p>
                    <div class="text-5xl mb-6 text-[#00D632]">$</div>
                    <h3 class="text-2xl font-bold uppercase text-white mb-4">Hard to find work</h3>
                    <p class="text-zinc-400 text-lg">Talented workers struggle with marketing, chasing payments, and keeping their schedule full.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="earn" class="py-24 px-6 bg-zinc-900 border-y border-white/10">
        <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-16 items-center">
            <div>
               <div class="inline-block px-3 py-1 border border-[#00D632] rounded-full text-[#00D632] text-xs font-bold uppercase tracking-widest mb-6">For Contractors & Freelancers</div>
               <h2 class="text-4xl md:text-6xl font-black uppercase tracking-tighter mb-6 text-white">Turn Your Skills Into <span class="text-[#00D632]">Income</span></h2>
               <p class="text-zinc-400 text-lg mb-8 leading-relaxed">
                   Stop chasing leads and payments. Join the verified network that brings jobs directly to you. 
               </p>
               
               <div class="space-y-8">
                  <div class="flex gap-4">
                     <div class="w-12 h-12 bg-[#00D632] rounded-xl flex items-center justify-center text-black font-black text-xl shrink-0">1</div>
                     <div>
                        <h4 class="font-bold text-white text-xl mb-1">Get Hired Instantly</h4>
                        <p class="text-zinc-500">Your profile is visible to thousands of locals. Receive job requests that match your skills.</p>
                     </div>
                  </div>
                  <div class="flex gap-4">
                     <div class="w-12 h-12 bg-[#00D632] rounded-xl flex items-center justify-center text-black font-black text-xl shrink-0">2</div>
                     <div>
                        <h4 class="font-bold text-white text-xl mb-1">Secure Payouts</h4>
                        <p class="text-zinc-500">No more bad debts. Payments are secured in the app and released when the job is done.</p>
                     </div>
                  </div>
                  <div class="flex gap-4">
                     <div class="w-12 h-12 bg-[#00D632] rounded-xl flex items-center justify-center text-black font-black text-xl shrink-0">3</div>
                     <div>
                        <h4 class="font-bold text-white text-xl mb-1">Work Your Way</h4>
                        <p class="text-zinc-500">Full-time or side hustle. You control your schedule and your rates.</p>
                     </div>
                  </div>
               </div>
            </div>
            
            <div class="relative">
                <div class="absolute inset-0 bg-[#00D632] blur-[120px] opacity-20"></div>
                <div class="relative z-10 rounded-[2.5rem] overflow-hidden border-8 border-zinc-800 shadow-2xl rotate-3 hover:rotate-0 transition duration-500">
                    <img src={homepageImg.src} alt="Contractors at work" class="w-full h-auto object-cover" />
                    <div class="absolute bottom-0 left-0 w-full p-8 bg-gradient-to-t from-black to-transparent">
                        <!-- <div class="bg-white/10 backdrop-blur-md border border-white/20 p-4 rounded-xl inline-block">
                            <p class="text-white font-bold text-sm">💰 Earned this week</p>
                            <p class="text-[#00D632] font-black text-2xl">RM 1,250.00</p>
                        </div> -->
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="features" class="py-24 px-6 bg-black">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-6xl font-black uppercase tracking-tighter mb-4">The Solution</h2>
                <p class="text-zinc-400 text-xl">We solve the problems for both sides of the deal.</p>
            </div>
            <div class="grid md:grid-cols-3 gap-8">
                <div class="group bg-zinc-900 p-8 rounded-[2rem] border border-white/10 hover:border-[#00D632] transition duration-300">
                    <div class="w-16 h-16 bg-black rounded-2xl flex items-center justify-center text-4xl mb-6 text-[#00D632]">🔀</div>
                    <h3 class="text-2xl font-black uppercase mb-4">Shuffle</h3>
                    <p class="text-zinc-400">Match Instantly. Whether you need a job done or a job to do, our algorithm connects the right people.</p>
                </div>
                <div class="group bg-zinc-900 p-8 rounded-[2rem] border border-white/10 hover:border-[#00D632] transition duration-300">
                    <div class="w-16 h-16 bg-black rounded-2xl flex items-center justify-center text-4xl mb-6 text-[#00D632]">📦</div>
                    <h3 class="text-2xl font-black uppercase mb-4">Hardware</h3>
                    <p class="text-zinc-400">Contractors can order parts directly to the site. No more driving back and forth to the store.</p>
                </div>
                <div class="group bg-zinc-900 p-8 rounded-[2rem] border border-white/10 hover:border-[#00D632] transition duration-300">
                    <div class="w-16 h-16 bg-black rounded-2xl flex items-center justify-center text-4xl mb-6 text-[#00D632]">🛡️</div>
                    <h3 class="text-2xl font-black uppercase mb-4">Verified</h3>
                    <p class="text-zinc-400">Identity checks for pros, secure payments for users. Safety is our priority.</p>
                </div>
            </div>
        </div>
    </section>
    
    <section id="faq" class="py-24 px-6 bg-zinc-900 relative">
       <div class="max-w-3xl mx-auto">
          <h2 class="text-3xl md:text-5xl font-black uppercase tracking-tighter mb-12 text-center">Frequently Asked <span class="text-[#00D632]">Questions</span></h2>
          
          <div class="space-y-4">
             <details class="group bg-black border border-white/10 rounded-xl overflow-hidden cursor-pointer transition-all hover:border-[#00D632]/50">
                <summary class="flex justify-between items-center p-6 text-lg font-bold text-white select-none">
                   Are there fees to use SkillBridge?
                   <span class="transform group-open:rotate-180 transition-transform duration-300 text-[#00D632]">▼</span>
                </summary>
                <div class="p-6 pt-0 text-zinc-400 leading-relaxed">
                   For homeowners, the app is free to use. For contractors, we charge a minimal <strong>3% commission</strong> on each completed job. 
                </div>
             </details>

             <details class="group bg-black border border-white/10 rounded-xl overflow-hidden cursor-pointer transition-all hover:border-[#00D632]/50">
                <summary class="flex justify-between items-center p-6 text-lg font-bold text-white select-none">
                   Can I join as a part-time worker?
                   <span class="transform group-open:rotate-180 transition-transform duration-300 text-[#00D632]">▼</span>
                </summary>
                <div class="p-6 pt-0 text-zinc-400 leading-relaxed">
                   Absolutely. You set your own availability. Whether you want to work full-time or just pick up jobs on weekends, SkillBridge works for you.
                </div>
             </details>

             <details class="group bg-black border border-white/10 rounded-xl overflow-hidden cursor-pointer transition-all hover:border-[#00D632]/50">
                <summary class="flex justify-between items-center p-6 text-lg font-bold text-white select-none">
                   How do payouts work?
                   <span class="transform group-open:rotate-180 transition-transform duration-300 text-[#00D632]">▼</span>
                </summary>
                <div class="p-6 pt-0 text-zinc-400 leading-relaxed">
                   Once a job is marked complete by the customer, the funds are released to your SkillBridge wallet, which you can cash out to your bank account.
                </div>
             </details>
          </div>
       </div>
    </section>

    <section id="team" class="py-32 px-6 bg-black">
        <div class="max-w-7xl mx-auto text-center">
            <h2 class="text-3xl font-bold uppercase tracking-[0.3em] text-zinc-500 mb-12">The Builders</h2>
            
            <div class="max-w-4xl mx-auto mb-16 relative group cursor-pointer">
                <div class="absolute -inset-1 bg-gradient-to-r from-[#00D632] to-blue-600 rounded-[2.5rem] blur opacity-25 group-hover:opacity-75 transition duration-1000 group-hover:duration-200"></div>
                <div class="relative rounded-[2rem] overflow-hidden border border-white/10 bg-black">
                    <img 
                        src={buildersImg.src} 
                        alt="The SkillBridge Team" 
                        class="w-full h-auto object-cover grayscale brightness-75 group-hover:grayscale-0 group-hover:brightness-100 transition duration-700 ease-in-out" 
                    />
                    <div class="absolute bottom-0 left-0 w-full p-8 bg-gradient-to-t from-black via-black/80 to-transparent text-left">
                         <p class="text-[#00D632] font-bold uppercase tracking-widest text-sm mb-1">Primate House • 2026</p>
                         <h3 class="text-2xl md:text-3xl font-black text-white">LaunchX Sunway</h3>
                    </div>
                </div>
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="bg-zinc-900 rounded-2xl p-8 hover:-translate-y-2 transition duration-300 border border-white/5">
                    <h3 class="text-2xl font-black text-white">Ronan</h3>
                    <div class="text-[#00D632] font-bold text-xs uppercase tracking-widest mb-4">CEO</div>
                    <p class="text-zinc-500 text-xs uppercase tracking-wide">Tech & Innovation</p>
                </div>
                <div class="bg-zinc-900 rounded-2xl p-8 hover:-translate-y-2 transition duration-300 border border-white/5">
                    <h3 class="text-2xl font-black text-white">Esmat</h3>
                    <div class="text-[#00D632] font-bold text-xs uppercase tracking-widest mb-4">CMO</div>
                    <p class="text-zinc-500 text-xs uppercase tracking-wide">Growth & Strategy</p>
                </div>
                <div class="bg-zinc-900 rounded-2xl p-8 hover:-translate-y-2 transition duration-300 border border-white/5">
                    <h3 class="text-2xl font-black text-white">Alister</h3>
                    <div class="text-[#00D632] font-bold text-xs uppercase tracking-widest mb-4">CAO</div>
                    <p class="text-zinc-500 text-xs uppercase tracking-wide">Ops & Admin</p>
                </div>
                <div class="bg-zinc-900 rounded-2xl p-8 hover:-translate-y-2 transition duration-300 border border-white/5">
                    <h3 class="text-2xl font-black text-white">Nurlaila</h3>
                    <div class="text-[#00D632] font-bold text-xs uppercase tracking-widest mb-4">CRO</div>
                    <p class="text-zinc-500 text-xs uppercase tracking-wide">Research</p>
                </div>
            </div>
        </div>
    </section>

    <footer id="contact" class="py-20 border-t border-white/10 bg-zinc-900">
        <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-10">
            <div class="text-left">
                <div class="text-4xl font-black tracking-tighter mb-4">SkillBridge</div>
                <p class="text-zinc-500 max-w-sm mb-6">Connecting Kuching's talent to opportunity. The smartest way to manage home repairs and finding work.</p>
                <div class="flex gap-4">
                    <a href="https://my.linkedin.com/company/skill-bridge-launchx?trk=public_post_follow-view-profile" target="_blank" class="w-10 h-10 bg-black rounded-full flex items-center justify-center hover:bg-[#00D632] hover:text-black transition cursor-pointer">LI</a>
                </div>
            </div>
            
            <div class="bg-black px-10 py-8 rounded-3xl text-center md:text-right border border-zinc-800">
                <p class="text-zinc-400 text-xs uppercase tracking-widest mb-2">Direct Line</p>
                <p class="text-2xl font-bold text-white mb-6">+6010-9221866</p>
                <a href="mailto:ronankuek@gmail.com" class="text-[#00D632] font-bold hover:underline">ronankuek@gmail.com</a>
                <p class="text-zinc-500 mt-2">Kuching, Sarawak</p>
            </div>
        </div>
        <div class="text-center mt-20 text-zinc-700 text-xs uppercase tracking-widest">
            © 2026 SkillBridge. Presented by Primate House.
        </div>
    </footer>

  </body>
</html>