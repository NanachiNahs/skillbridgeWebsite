---
// This is the "Frontmatter" - Server-side Javascript goes here
const pageTitle = "SkillBridge";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
  </head>
  <body class="bg-slate-50 text-slate-800">
    
    <nav class="flex justify-between items-center p-6 bg-white shadow-sm">
      <div class="text-2xl font-bold text-blue-600">SkillBridge</div>
      <div>
        <a href="#about" class="px-4 py-2 hover:text-blue-600">About</a>
        <a href="#contact" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Get Started</a>
      </div>
    </nav>

    <main class="max-w-4xl mx-auto mt-20 text-center px-4">
      <h1 class="text-5xl font-extrabold mb-6">
        Connecting Talent to <span class="text-blue-600">Opportunity</span>
      </h1>
      <p class="text-xl text-slate-600 mb-10">
        Bridging the gap between skilled professionals and the businesses that need them.
        Simple, fast, and reliable.
      </p>
      <div class="space-x-4">
        <button class="px-8 py-3 bg-blue-600 text-white font-semibold rounded-lg shadow-lg hover:bg-blue-700 transition">
          Find Work
        </button>
        <button class="px-8 py-3 bg-white text-blue-600 font-semibold rounded-lg shadow border border-slate-200 hover:bg-slate-50 transition">
          Find Talent
        </button>
      </div>
    </main>

    <footer class="mt-20 text-center text-slate-400 py-10">
      <p>&copy; 2026 SkillBridge. All rights reserved.</p>
    </footer>

  </body>
</html>