---
import '../styles/global.css';
const pageTitle = "SkillBridge Admin - Login";
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    
    <style>
      .bg-grid {
        background-size: 50px 50px;
        background-image: linear-gradient(to right, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
                          linear-gradient(to bottom, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
      }
    </style>
  </head>
  
  <body class="bg-black text-white font-['Inter'] selection:bg-[#00D632] selection:text-black min-h-screen flex items-center justify-center overflow-hidden bg-grid relative">
    
    <!-- Background glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#00D632] rounded-full blur-[150px] opacity-10 pointer-events-none"></div>

    <div class="relative z-10 w-full max-w-md p-8 bg-zinc-900/80 backdrop-blur-xl border border-white/10 rounded-[2rem] shadow-2xl mx-4">
      <div class="text-center mb-8">
        <div class="w-16 h-16 bg-[#00D632] rounded-2xl mx-auto flex items-center justify-center text-black font-black text-3xl mb-6 shadow-[0_0_20px_rgba(0,214,50,0.5)]">S</div>
        <h1 class="text-3xl font-black uppercase tracking-tighter">Admin <span class="text-[#00D632]">Login</span></h1>
        <p class="text-zinc-400 mt-2">Access the SkillBridge management console</p>
      </div>

      <form id="loginForm" class="space-y-6">
        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-2">Email Address</label>
          <input 
            type="email" 
            id="email" 
            required
            class="w-full bg-black border border-zinc-800 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#00D632] transition"
            placeholder="admin@skillbridge.com"
          />
        </div>
        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-2">Password</label>
          <input 
            type="password" 
            id="password" 
            required
            class="w-full bg-black border border-zinc-800 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#00D632] transition"
            placeholder="••••••••"
          />
        </div>

        <div id="errorMessage" class="hidden bg-red-500/10 border border-red-500/50 text-red-500 text-sm p-3 rounded-lg text-center"></div>

        <button 
          type="submit" 
          id="submitBtn"
          class="w-full px-6 py-4 bg-[#00D632] text-black font-black uppercase tracking-wider text-sm rounded-xl hover:bg-white transition duration-300 shadow-[0_0_20px_rgba(0,214,50,0.4)] flex justify-center items-center"
        >
          <span>Sign In</span>
        </button>
      </form>
    </div>

    <script>
      // If already logged in, skip login page
      const existingSession = document.cookie.split(';').find(c => c.trim().startsWith('sb_admin_session='));
      if (existingSession) {
        window.location.href = '/home';
      }

      const form = document.getElementById('loginForm') as HTMLFormElement;
      const emailInput = document.getElementById('email') as HTMLInputElement;
      const passwordInput = document.getElementById('password') as HTMLInputElement;
      const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
      const errorMessage = document.getElementById('errorMessage');

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Reset states
        if (errorMessage) errorMessage.classList.add('hidden');
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="animate-pulse">Authenticating...</span>';

        const email = emailInput.value.trim();
        const password = passwordInput.value;

        try {
          // Authenticate via server-side API (bypasses RLS)
          const res = await fetch('/api/admin/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password })
          });
          const json = await res.json();

          if (!json.ok) {
            throw new Error(json.error || 'Invalid email or password');
          }

          // Successful login
          submitBtn.innerHTML = '<span>Success! Redirecting...</span>';
          submitBtn.classList.replace('bg-[#00D632]', 'bg-white');
          
          const sessionData = JSON.stringify(json.admin);

          // Store in localStorage (for client-side reads)
          localStorage.setItem('sb_admin', sessionData);

          // Also set a cookie so the server-side middleware can protect routes
          document.cookie = `sb_admin_session=${encodeURIComponent(sessionData)}; path=/; max-age=${60 * 60 * 8}; SameSite=Strict`;

          setTimeout(() => {
            window.location.href = '/home'; 
          }, 1000);

        } catch (err: any) {
          if (errorMessage) {
            errorMessage.textContent = err.message || 'An error occurred during login';
            errorMessage.classList.remove('hidden');
          }
          submitBtn.disabled = false;
          submitBtn.innerHTML = '<span>Sign In</span>';
        }
      });
    </script>
  </body>
</html>
