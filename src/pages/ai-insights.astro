---
import '../styles/global.css';
import SideMenu from '../components/SideMenu.astro';

const pageTitle = "SkillBridge Admin - AI Insights";
---

<html lang="en" class="scroll-smooth overflow-x-clip">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet">

    <style>
      .bg-grid {
        background-size: 40px 40px;
        background-image: linear-gradient(to right, rgba(255,255,255,0.03) 1px, transparent 1px),
                          linear-gradient(to bottom, rgba(255,255,255,0.03) 1px, transparent 1px);
      }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: #000; }
      ::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }
      ::-webkit-scrollbar-thumb:hover { background: #a855f7; }
      .glass-card {
        background: rgba(24,24,27,0.85);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.06);
      }
      /* Typing indicator dots */
      .typing-dot { animation: bounce 1.2s infinite; }
      .typing-dot:nth-child(2) { animation-delay: 0.2s; }
      .typing-dot:nth-child(3) { animation-delay: 0.4s; }
      @keyframes bounce {
        0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
        40% { transform: translateY(-5px); opacity: 1; }
      }
      /* Message fade-in */
      .msg-enter { animation: msgIn 0.25s ease-out; }
      @keyframes msgIn {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      /* Suggestion chips */
      .chip:hover { background: rgba(168,85,247,0.15); border-color: rgba(168,85,247,0.5); }
      /* Auto-grow textarea */
      #chatInput { resize: none; min-height: 52px; max-height: 160px; overflow-y: auto; font-size: 1rem; }
    </style>
  </head>

  <body class="bg-black text-white font-['Inter'] selection:bg-purple-500 selection:text-white min-h-screen bg-grid overflow-x-hidden">

    <SideMenu />

    <main class="lg:ml-64 pt-16 lg:pt-0 flex flex-col h-screen">

      <!-- Top Bar -->
      <div class="shrink-0 flex items-center justify-between px-6 py-5 border-b border-white/10 bg-black/60 backdrop-blur-xl">
        <div class="flex items-center gap-4">
        </br>
          <div class="w-10 h-10 bg-purple-500/20 rounded-xl flex items-center justify-center border border-purple-500/40 text-purple-400 shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <div>
            <h1 class="text-base lg:text-xl font-black uppercase tracking-tight">SkillBridge <span class="text-purple-400">AI</span></h1>
            <p class="text-xs lg:text-sm text-zinc-500">Powered by Gemini 2.5 Flash · Aware of live platform data</p>
          </div>
        </div>
        <button id="clearChat"
          class="text-xs lg:text-sm text-zinc-600 hover:text-red-400 border border-white/5 hover:border-red-500/30 px-3 py-1.5 rounded-lg transition-colors font-bold uppercase tracking-wider">
          Clear Chat
        </button>
      </div>

      <!-- Chat Messages -->
      <div id="chatMessages" class="flex-1 overflow-y-auto overflow-x-hidden px-4 sm:px-6 py-6 space-y-6">

        <!-- Welcome message (shown when chat is empty) -->
        <div id="welcomeBlock" class="max-w-3xl mx-auto">
          <div class="text-center mb-10 pt-4">
            <div class="w-16 h-16 bg-purple-500/20 rounded-2xl flex items-center justify-center border border-purple-500/30 mx-auto mb-4">
              <svg class="w-8 h-8 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <h2 class="text-xl lg:text-3xl font-black text-white mb-2">How can I help you today?</h2>
            <p class="text-zinc-500 text-sm lg:text-base">Ask me anything about your platform — bookings, contractors, revenue, growth strategy.</p>
          </div>

          <!-- Suggestion chips -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {[
              { icon: '📊', text: 'How are bookings trending this month?' },
              { icon: '🏙️', text: 'Which city should we expand to next?' },
              { icon: '⚠️', text: 'What is our current churn risk?' },
              { icon: '💰', text: 'What is our estimated revenue for Q3?' },
              { icon: '🔧', text: 'Who are the top performing contractors?' },
              { icon: '📉', text: 'Why are there disputed bookings?' },
            ].map(chip => (
              <button class="chip text-left px-3 py-3 lg:px-4 lg:py-4 rounded-xl border border-white/8 text-zinc-300 text-sm lg:text-base transition-colors flex items-start gap-3 bg-zinc-900/40"
                data-prompt={chip.text}>
                <span class="text-base lg:text-xl shrink-0">{chip.icon}</span>
                <span>{chip.text}</span>
              </button>
            ))}
          </div>
        </div>
      </div>

      <!-- Input Bar -->
      <div class="shrink-0 border-t border-white/5 bg-black/60 backdrop-blur-xl px-4 sm:px-6 py-4">
        <div class="max-w-3xl mx-auto">
          <div class="flex items-end gap-3 glass-card rounded-2xl border border-white/10 px-4 py-3 focus-within:border-purple-500/50 transition-colors">
            <textarea
              id="chatInput"
              placeholder="Ask anything about your platform..."
              rows="1"
              class="flex-1 bg-transparent text-white placeholder-zinc-600 text-sm lg:text-base outline-none leading-relaxed"
            ></textarea>
            <button id="sendBtn"
              class="w-9 h-9 rounded-xl bg-purple-500 hover:bg-purple-400 disabled:opacity-40 disabled:cursor-not-allowed flex items-center justify-center transition-colors shrink-0"
              disabled>
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </button>
          </div>
          <p class="text-center text-zinc-600 text-xs mt-2">AI responses are based on live Supabase data. Always verify before acting.</p>
        </div>
      </div>
    </main>

    <script>
      // --- Session management ---
      const STORAGE_KEY = 'sb_ai_chat_history';

      interface Message { role: 'user' | 'model'; text: string; ts: number; }

      let history: Message[] = [];

      function saveHistory() {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(history));
      }

      function loadHistory(): Message[] {
        try {
          return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
        } catch { return []; }
      }

      // --- DOM refs ---
      const chatMessages  = document.getElementById('chatMessages') as HTMLDivElement;
      const chatInput     = document.getElementById('chatInput') as HTMLTextAreaElement;
      const sendBtn       = document.getElementById('sendBtn') as HTMLButtonElement;
      const clearBtn      = document.getElementById('clearChat') as HTMLButtonElement;
      const welcomeBlock  = document.getElementById('welcomeBlock') as HTMLDivElement;

      // --- Auth guard ---
      if (!localStorage.getItem('sb_admin')) window.location.href = '/login';

      // --- Render a single message bubble ---
      function renderMessage(msg: Message, animate = false) {
        const isUser = msg.role === 'user';
        const time   = new Date(msg.ts).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

        const wrapper = document.createElement('div');
        wrapper.className = `flex ${isUser ? 'justify-end' : 'justify-start'} ${animate ? 'msg-enter' : ''}`;

        // Convert newlines to <br> and bold **text**
        const formatted = msg.text
          .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
          .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
          .replace(/\n/g, '<br>');

        wrapper.innerHTML = isUser ? `
          <div class="max-w-[85%] sm:max-w-[70%] min-w-0">
            <div class="bg-purple-600/80 text-white rounded-2xl rounded-br-sm px-3 py-2.5 lg:px-5 lg:py-4 text-sm lg:text-base leading-relaxed break-words overflow-hidden">${formatted}</div>
            <div class="text-right text-xs text-zinc-500 mt-1 pr-1">${time}</div>
          </div>` : `
          <div class="max-w-[92%] sm:max-w-[80%] flex gap-2 lg:gap-3 min-w-0">
            <div class="w-7 h-7 lg:w-9 lg:h-9 rounded-xl bg-purple-500/20 border border-purple-500/30 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <div class="min-w-0 flex-1">
              <div class="glass-card rounded-2xl rounded-tl-sm px-3 py-2.5 lg:px-5 lg:py-4 text-sm lg:text-base leading-relaxed text-zinc-100 border border-purple-500/10 break-words overflow-hidden">${formatted}</div>
              <div class="text-xs text-zinc-500 mt-1 pl-1">${time}</div>
            </div>
          </div>`;

        chatMessages.appendChild(wrapper);
        chatMessages.scrollTop = chatMessages.scrollHeight;
      }

      // --- Typing indicator ---
      let typingEl: HTMLDivElement | null = null;
      function showTyping() {
        typingEl = document.createElement('div');
        typingEl.className = 'flex justify-start msg-enter';
        typingEl.innerHTML = `
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-xl bg-purple-500/20 border border-purple-500/30 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <div class="glass-card rounded-2xl rounded-tl-sm px-5 py-4 border border-purple-500/10 flex gap-1.5 items-center">
              <span class="typing-dot w-2 h-2 rounded-full bg-purple-400 inline-block"></span>
              <span class="typing-dot w-2 h-2 rounded-full bg-purple-400 inline-block"></span>
              <span class="typing-dot w-2 h-2 rounded-full bg-purple-400 inline-block"></span>
            </div>
          </div>`;
        chatMessages.appendChild(typingEl);
        chatMessages.scrollTop = chatMessages.scrollHeight;
      }
      function hideTyping() { typingEl?.remove(); typingEl = null; }

      // --- Send message ---
      async function sendMessage(text: string) {
        if (!text.trim()) return;

        // Hide welcome block on first message
        welcomeBlock.style.display = 'none';

        const userMsg: Message = { role: 'user', text: text.trim(), ts: Date.now() };
        history.push(userMsg);
        saveHistory();
        renderMessage(userMsg, true);

        chatInput.value = '';
        chatInput.style.height = 'auto';
        sendBtn.disabled = true;
        showTyping();

        try {
          const res = await fetch('/api/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              message: text.trim(),
              // Send only the last 20 turns to avoid token limits
              history: history.slice(-20).slice(0, -1).map(m => ({ role: m.role, text: m.text }))
            })
          });

          const json = await res.json();
          hideTyping();

          if (json.ok) {
            const aiMsg: Message = { role: 'model', text: json.reply, ts: Date.now() };
            history.push(aiMsg);
            saveHistory();
            renderMessage(aiMsg, true);
          } else {
            throw new Error(json.error || 'Unknown error');
          }
        } catch (err: any) {
          hideTyping();
          // Show a friendly message instead of the raw API error
          const msg = err.message || '';
          let friendlyText = '⚠️ Something went wrong. Please try again in a moment.';
          if (msg.includes('429') || msg.toLowerCase().includes('quota') || msg.toLowerCase().includes('rate')) {
            friendlyText = '⚠️ The AI is a bit busy right now (rate limit reached). Please wait a few seconds and try again.';
          } else if (msg.includes('500') || msg.toLowerCase().includes('internal')) {
            friendlyText = '⚠️ The server ran into an error. Please try again.';
          } else if (msg.toLowerCase().includes('network') || msg.toLowerCase().includes('fetch')) {
            friendlyText = '⚠️ Network issue — check your connection and try again.';
          }
          const errMsg: Message = { role: 'model', text: friendlyText, ts: Date.now() };
          renderMessage(errMsg, true);
        }

        sendBtn.disabled = chatInput.value.trim().length === 0;
      }

      // --- Input handlers ---
      chatInput.addEventListener('input', () => {
        // Auto-grow
        chatInput.style.height = 'auto';
        chatInput.style.height = chatInput.scrollHeight + 'px';
        sendBtn.disabled = chatInput.value.trim().length === 0;
      });

      chatInput.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          if (!sendBtn.disabled) sendMessage(chatInput.value);
        }
      });

      sendBtn.addEventListener('click', () => sendMessage(chatInput.value));

      // --- Suggestion chips ---
      document.querySelectorAll('.chip').forEach(chip => {
        chip.addEventListener('click', () => {
          const prompt = (chip as HTMLElement).dataset.prompt || '';
          sendMessage(prompt);
        });
      });

      // --- Clear chat ---
      clearBtn.addEventListener('click', () => {
        if (!confirm('Clear all chat history?')) return;
        history = [];
        saveHistory();
        // Re-render just the welcome block
        chatMessages.innerHTML = '';
        welcomeBlock.style.display = '';
        chatMessages.appendChild(welcomeBlock);
        welcomeBlock.style.display = '';
      });

      // --- Load saved history on page open ---
      history = loadHistory();
      if (history.length > 0) {
        welcomeBlock.style.display = 'none';
        history.forEach(msg => renderMessage(msg, false));
      }

      // Focus input
      chatInput.focus();
    </script>
  </body>
</html>
