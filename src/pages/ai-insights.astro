---
import '../styles/global.css';
import SideMenu from '../components/SideMenu.astro';
import { createClient } from '@supabase/supabase-js';
import { GoogleGenerativeAI } from '@google/generative-ai';

const pageTitle = "SkillBridge Admin - AI Insights";

// Initialize Supabase
const supabaseUrl = import.meta.env.EXPO_PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.EXPO_PUBLIC_SUPABASE_ANON_KEY;
const supabase = createClient(supabaseUrl, supabaseAnonKey);

// Initialize Gemini (Note: Using your EXPO_PUBLIC_GEMINI_API_KEY from .env)
const genAI = new GoogleGenerativeAI(import.meta.env.EXPO_PUBLIC_GEMINI_API_KEY);
const model = genAI.getGenerativeModel({ model: "gemini-2.5-flash" });

let aiInsight = "Analyzing platform data...";

try {
  // Fetch recent bookings
  const { data: bookings } = await supabase
    .from('bookings')
    .select('status, created_at, users(first_name), contractors(business_name)')
    .order('created_at', { ascending: false })
    .limit(50);

  if (bookings && bookings.length > 0) {
    const prompt = `
      You are an expert business analyst for SkillBridge, a blue-collar home services app. 
      Here is the JSON data for our most recent bookings:
      ${JSON.stringify(bookings)}
      
      Based on this data, write a 2-3 sentence actionable business insight for the admin dashboard.
      Keep it professional. Focus on trends, statuses (like completed vs pending vs cancelled), or activity levels.
      Do not format with markdown or headers, just plain text.
    `;

    const result = await model.generateContent(prompt);
    aiInsight = result.response.text();
  } else {
    aiInsight = "Not enough data available to generate insights yet.";
  }
} catch (e: any) {
  console.error("AI Analysis failed:", e);
  aiInsight = "Error: " + (e.message || "Unknown error occurred.");
}
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet">

    <style>
      .bg-grid {
        background-size: 40px 40px;
        background-image: linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px),
                          linear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
      }
      ::-webkit-scrollbar { width: 8px; }
      ::-webkit-scrollbar-track { background: #000; }
      ::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }
      ::-webkit-scrollbar-thumb:hover { background: #00D632; }
      .glass-card {
        background: rgba(24, 24, 27, 0.8);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.05);
      }
    </style>
  </head>
  
  <body class="bg-black text-white font-['Inter'] selection:bg-[#00D632] selection:text-black min-h-screen bg-grid overflow-x-hidden">

    <SideMenu />

    <main class="ml-64 p-8 relative">
        <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-purple-600 rounded-full blur-[150px] opacity-10 pointer-events-none"></div>

        <div class="relative z-10 max-w-7xl mx-auto space-y-8">
            <header class="flex justify-between items-end">
                <div>
                    <h1 class="text-3xl font-black uppercase tracking-tighter mb-1">AI <span class="text-purple-400">Insights</span></h1>
                    <p class="text-zinc-400 text-sm">Advanced machine learning predictions and analytics.</p>
                </div>
            </header>

            <div class="glass-card p-8 rounded-2xl border border-purple-500/30">
                <div class="flex items-center gap-4 mb-6">
                    <div class="w-12 h-12 bg-purple-500/20 rounded-xl flex items-center justify-center border border-purple-500/50 text-purple-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    </div>
                    <div>
                        <h2 class="text-xl font-bold text-white uppercase tracking-wider">Latest Platform Analysis</h2>
                        <p class="text-purple-300/80 text-sm">Powered by Gemini 2.5 Flash</p>
                    </div>
                </div>
                
                <p class="text-white text-lg leading-relaxed font-medium">
                    {aiInsight}
                </p>
            </div>
        </div>
    </main>

    <script>
      // Ensure Admin is logged in
      const adminData = localStorage.getItem('sb_admin');
      if (!adminData) {
        window.location.href = '/login';
      }
    </script>
  </body>
</html>
